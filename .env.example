# =============================================================================
# SERVICIO: api  (apps/api)
# =============================================================================

# --- Supabase (base de datos) ------------------------------------------------
# CRÍTICO: sin estas variables el servidor no puede leer/escribir llamadas,
# clientes ni vendedores. El proceso arranca pero todas las sesiones fallarán
# al intentar cargar contexto o guardar resultados.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Deepgram (transcripción en tiempo real) ---------------------------------
# CRÍTICO: sin esta clave no hay transcripción de audio. Las sesiones de
# coaching no pueden iniciarse.
DEEPGRAM_API_KEY=your-deepgram-api-key

# --- Anthropic / Claude (sugerencias de coaching) ----------------------------
# CRÍTICO: sin esta clave no se generan sugerencias ni resúmenes de llamada.
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Configuración del servidor ----------------------------------------------
PORT=3001
# Origen permitido para CORS (URL del servicio web en Railway)
ALLOWED_ORIGIN=https://your-web-service.up.railway.app


# =============================================================================
# SERVICIO: web  (apps/web)
# =============================================================================
# Nota: las variables NEXT_PUBLIC_* son bakeadas en el bundle del cliente
# durante el build de Next.js. Deben estar disponibles como Build Variables
# en Railway (no solo como Runtime Variables).

# --- Supabase (consultas desde el frontend / Server Components) --------------
# DEGRADACIÓN: si faltan, la app carga con un banner de advertencia visible y
# todas las páginas muestran estructura visual vacía (sin datos). No hay crash.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- URL del servidor de WebSocket (coaching en tiempo real) -----------------
# DEGRADACIÓN: si falta, CallCoach muestra un aviso en la UI y usa el fallback
# ws://localhost:3001/ws (que no funcionará en producción). Sin crash.
NEXT_PUBLIC_API_WS_URL=wss://your-api-service.up.railway.app/ws
